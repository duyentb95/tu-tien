# Copy file này thành `.env.local` và điền giá trị thật. KHÔNG commit `.env*`.

# ────────── GOOGLE GEMINI ──────────
# Lấy key tại: https://aistudio.google.com/apikey (mỗi key free 1500 req/day)
#
# Có 2 cách config:
#   1. Single key (legacy, đủ cho dev):
VITE_GEMINI_API_KEY=

#   2. Multi-key rotation (recommend cho production — tăng quota gấp N lần,
#      tránh 429 rate limit, tránh 503 spike. Tạo N Google account → mỗi cái 1 key).
#      App tự round-robin + block key tạm thời nếu bị 429/403:
# VITE_GEMINI_API_KEY_1=AIzaSy...
# VITE_GEMINI_API_KEY_2=AIzaSy...
# VITE_GEMINI_API_KEY_3=AIzaSy...
# (support tới _10. Có thể trộn cả VITE_GEMINI_API_KEY + VITE_GEMINI_API_KEY_N.)

# Model override (optional). Default: gemini-2.5-flash.
# Options: gemini-2.5-flash (recommend) / gemini-2.5-flash-lite (cheap) / gemini-2.5-pro (quality) / gemini-2.0-flash (backup)
# VITE_GEMINI_MODEL=gemini-2.5-flash

# ────────── DEEPSEEK (Phase 8.1 — optional, văn phong tu tiên tốt hơn) ──────────
# Lấy key tại: https://platform.deepseek.com/api_keys ($5 trial credit)
# Khi có DeepSeek key, narrative engine sẽ tự động dùng DeepSeek (default 'auto')
# Logic engine vẫn dùng Gemini (rẻ + JSON tốt).
# Cost ~$0.002/turn DeepSeek (vs $0.0006 Gemini Flash) — vẫn rẻ, văn phong đẹp hơn rõ
# VITE_DEEPSEEK_API_KEY=sk-xxx
# VITE_DEEPSEEK_API_KEY_1=sk-aaa
# VITE_DEEPSEEK_API_KEY_2=sk-bbb     # rotation optional
# VITE_DEEPSEEK_MODEL=deepseek-chat  # hoặc deepseek-reasoner (R1, chậm hơn nhưng reasoning sâu)

# Proxy URL riêng cho DeepSeek (ẩn key server-side, recommend production):
# VITE_AI_PROXY_URL_DEEPSEEK=https://your-worker.workers.dev/chat-deepseek

# ────────── FIREBASE ──────────
# Console: https://console.firebase.google.com → Project settings → General
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
